#───────────────────────────────────────────────────────────────────────────────
# Souli — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#───────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUD PLATFORM
# ═══════════════════════════════════════════════════════════════════════════════

# Choose your primary cloud platform: "gcp" or "aws"
CLOUD_PLATFORM=aws

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER & COMPOSE
# ═══════════════════════════════════════════════════════════════════════════════

# Docker Compose project name
COMPOSE_PROJECT_NAME=souli

# ═══════════════════════════════════════════════════════════════════════════════
# LANGUAGE MODELS — OLLAMA
# ═══════════════════════════════════════════════════════════════════════════════

# Chat model for conversational responses
OLLAMA_CHAT_MODEL=llama3.1

# Smaller model for intent tagging (lightweight)
OLLAMA_TAGGER_MODEL=qwen2.5:1.5b

# ═══════════════════════════════════════════════════════════════════════════════
# VECTOR STORE — QDRANT
# ═══════════════════════════════════════════════════════════════════════════════

# Collection name for storing embeddings
QDRANT_COLLECTION=souli_chunks

# Qdrant server port (default: 6333)
QDRANT_PORT=6333

# API key for Qdrant authentication (only if enabled in Qdrant config)
QDRANT_API_KEY=your_qdrant_api_key_here

# Cloud Qdrant host URL (e.g., xxx.cloud.qdrant.io) — leave blank for local
QDRANT_HOST=your_qdrant_host_here

# ═══════════════════════════════════════════════════════════════════════════════
# VOICE COMMUNICATION — LIVEKIT & DEEPGRAM
# ═══════════════════════════════════════════════════════════════════════════════

# OPTION A: LiveKit Cloud (Recommended)
# Sign up at livekit.io/cloud → create a project → copy credentials below
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM=souli-room

# Speech-to-text provider
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OPTION B: Self-hosted LiveKit on VM (Uncomment to use instead of Cloud)
# LIVEKIT_URL=ws://YOUR_VM_EXTERNAL_IP:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret

# ═══════════════════════════════════════════════════════════════════════════════
# TEXT-TO-SPEECH
# ═══════════════════════════════════════════════════════════════════════════════

# Azure TTS voice code (see: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support)
TTS_VOICE=en-IN-NeerjaNeural

# ═══════════════════════════════════════════════════════════════════════════════
# GENERATIVE AI — GEMINI (Vertex AI + Direct API)
# ═══════════════════════════════════════════════════════════════════════════════

# GCP Project ID (required for Vertex AI authentication)
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for Vertex AI (e.g., us-central1, europe-west1)
GCP_LOCATION=us-central1

# Setup: Run once before docker compose up
#   gcloud auth application-default login
#   gcloud auth application-default set-quota-project YOUR_GCP_PROJECT_ID
#
# Credentials location:
#   Mac:     ~/.config/gcloud/application_default_credentials.json
#   Windows: %APPDATA%\gcloud\application_default_credentials.json
#   Linux:   /home/ubuntu/.config/gcloud/application_default_credentials.json

# Direct Gemini API key (alternative to Vertex AI — leave blank if using Vertex AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Fast model for most phases (intake, intent, solution stage 1)
# See models: https://ai.google.dev/gemini-api/docs/models/gemini
GEMINI_FLASH_MODEL=gemini-2.5-flash-preview-05-20

# Advanced model for complex reasoning (solution stage 2, summary generation)
# Use sparingly — more expensive than flash
GEMINI_PRO_MODEL=gemini-2.5-pro-preview-05-06




# Path to your gcloud credentials folder
# Mac/Linux: ~/.config/gcloud  → use: /Users/yourname/.config/gcloud
# EC2:       /home/ubuntu/.config/gcloud
GCLOUD_CONFIG_DIR=/home/ubuntu/.config/gcloud


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE — MONGODB ATLAS
# ═══════════════════════════════════════════════════════════════════════════════

# MongoDB Atlas connection URI (get from Atlas > Connect > Drivers)
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Database name for storing session benchmarks and results
MONGODB_DB_NAME=souli_benchmark

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION LOGGING & CONFIG
# ═══════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SOULI_LOG_LEVEL=INFO

# Configuration file path
# Use: configs/pipeline.yaml (works for both AWS & GCP)
#      configs/pipeline.aws.yaml (AWS-specific features)
#      configs/pipeline.gcp.yaml (GCP-specific features)
SOULI_CONFIG_PATH=configs/pipeline.yaml


# ═══════════════════════════════════════════════════════════════════════════════
# AWS DEPLOYMENT (only if CLOUD_PLATFORM=aws)
# ═══════════════════════════════════════════════════════════════════════════════

# ── AWS Credentials & Region ────────────────────────────────────────────────────

# AWS region (e.g., ap-south-1, us-east-1, eu-west-1)
AWS_REGION=ap-south-1

# Named profile from ~/.aws/credentials
AWS_PROFILE=default

# Public IP of EC2 instance (auto-populated after creation)
AWS_PUBLIC_IP=

# ── EC2 Instance Configuration ──────────────────────────────────────────────────

# Display name for the EC2 instance in AWS console
EC2_INSTANCE_NAME=souli-ai-vm

# Instance type: g5.2xlarge (1x A10G GPU, 8 vCPU, 32GB)
# Other options: g4dn.xlarge, g4dn.2xlarge, p3.2xlarge, m5.xlarge
EC2_INSTANCE_TYPE=g5.2xlarge

# SSH key pair name (will be created if missing)
EC2_KEY_PAIR_NAME=souli-ai-key

# Security group name (will be created if missing)
EC2_SECURITY_GROUP=souli-ai-sg

# EBS volume size in GB
EC2_DISK_SIZE=80

# Instance ID (auto-populated after creation)
EC2_INSTANCE_ID=

# ── Optional EC2 Settings ──────────────────────────────────────────────────────

# SSH key file path (leave empty if public key already added to instance)
# EC2_KEY_FILE=./keys/souli-ai-key.pem

# SSH user for the AMI (defaults to ubuntu for Ubuntu AMIs)
# EC2_SSH_USER=ubuntu

# Custom VPC subnet ID (leave unset for default VPC)
# EC2_SUBNET_ID=subnet-xxxxx

# Custom AMI ID (defaults to latest Ubuntu 22.04)
# EC2_AMI_ID=ami-xxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════════
# GCP DEPLOYMENT (only if CLOUD_PLATFORM=gcp)
# ═══════════════════════════════════════════════════════════════════════════════

# GCP project ID
# GCE_PROJECT=your-gcp-project-id

# VM instance name
# GCE_VM_NAME=souli-vm

# Compute zone (e.g., us-central1-a, europe-west1-b)
# GCE_ZONE=us-central1-a

# Machine type (e.g., n1-standard-4, e2-medium)
# GCE_MACHINE_TYPE=n1-standard-4

# GPU type (leave blank for CPU-only): nvidia-tesla-t4, nvidia-tesla-k80
# GCE_GPU_TYPE=nvidia-tesla-t4

# Boot disk size in GB
# GCE_DISK_SIZE=100

# ═══════════════════════════════════════════════════════════════════════════════
# REPOSITORY
# ═══════════════════════════════════════════════════════════════════════════════

# GitHub repository URL (used by deployment scripts)
SOULI_REPO_URL=https://github.com/LeapX-Tech/soul-i
