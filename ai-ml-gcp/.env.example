# ─────────────────────────────────────────────────────────────────────────────
# Souli — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Choose Your Cloud Platform ─────────────────────────────────────────────────
# Set to either "gcp" or "aws"
CLOUD_PLATFORM=aws

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER — Common Settings
# ═══════════════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=souli

# ── Ollama models ─────────────────────────────────────────────────────────────
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_TAGGER_MODEL=qwen2.5:1.5b

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=souli_chunks
QDRANT_PORT=6333
QDRANT_API_KEY = your_qdrant_api_key_here   # Only needed if you set up API key auth in Qdrant
QDRANT_HOST=your_qdrant_host_here           # Cloud Qdrant host URL (e.g., xxx.cloud.qdrant.io)

# ── LiveKit voice rooms ───────────────────────────────────────────────────────
# Option A: LiveKit Cloud (recommended — free tier at livekit.io/cloud)
#   Sign up → create a project → copy URL and keys below
LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM=souli-room

# Option B: Self-hosted LiveKit on the VM
# LIVEKIT_URL=ws://YOUR_VM_EXTERNAL_IP:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret

# ── Souli logging & Config ────────────────────────────────────────────────────
SOULI_LOG_LEVEL=INFO
SOULI_CONFIG_PATH=configs/pipeline.yaml   # Change to pipeline.gcp.yaml if using GCP
#configs/pipeline.aws.yaml # if working on AWS-specific features, otherwise pipeline.yaml works for both


# ═══════════════════════════════════════════════════════════════════════════════
# GEMINI (new — added for 2-week Gemini testing phase)
# ═══════════════════════════════════════════════════════════════════════════════

GEMINI_API_KEY=your_gemini_api_key_here
# Model for all phases EXCEPT solution (fast + cheap)
# Check exact string at: https://ai.google.dev/gemini-api/docs/models
GEMINI_FLASH_MODEL=gemini-2.5-flash-preview-05-20

# Model for solution phase only (smarter, used sparingly)
GEMINI_PRO_MODEL=gemini-2.5-pro-preview-05-06


# ═══════════════════════════════════════════════════════════════════════════════
# MONGODB ATLAS (new — for session benchmarking storage)
# ═══════════════════════════════════════════════════════════════════════════════

# Atlas connection URI — get from MongoDB Atlas > Connect > Drivers
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Database name — all Gemini sessions stored here
# You can leave this as-is or rename it
MONGODB_DB_NAME=souli_benchmark


# ═══════════════════════════════════════════════════════════════════════════════
# AWS SETTINGS (only if CLOUD_PLATFORM=aws)
# ═══════════════════════════════════════════════════════════════════════════════

# AWS credentials & configuration
AWS_REGION=ap-south-1
AWS_PROFILE=default                                 # Named profile in ~/.aws/credentials
AWS_PUBLIC_IP=                                      # Populated after instance creation

# EC2 Instance Configuration
EC2_INSTANCE_NAME=souli-ai-vm                       # Name tag for the instance

EC2_INSTANCE_TYPE=g5.2xlarge                        # 1x A10G GPU, 8 vCPU, 32GB RAM
                                                    # Other options: g4dn.xlarge, g4dn.2xlarge, p3.2xlarge

EC2_KEY_PAIR_NAME=souli-ai-key                      # SSH key pair name (will be created if missing)
EC2_SECURITY_GROUP=souli-ai-sg                      # Security group name (will be created if missing)
EC2_DISK_SIZE=80                                    # EBS volume size in GB
EC2_INSTANCE_ID=                                    # Populated after instance creation

# Optional: SSH key file path (leave empty if your public key was added to the instance)
# EC2_KEY_FILE=./keys/souli-ai-key.pem

# Optional: SSH user (defaults to ubuntu for Ubuntu AMIs)
# EC2_SSH_USER=ubuntu

# Optional: specify custom VPC subnet
# EC2_SUBNET_ID=subnet-xxxxx

# Optional: use specific AMI (defaults to latest Ubuntu 22.04)
# EC2_AMI_ID=ami-xxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════════
# GCP SETTINGS (only if CLOUD_PLATFORM=gcp)
# ═══════════════════════════════════════════════════════════════════════════════

# GCE_PROJECT=your-gcp-project-id
# GCE_VM_NAME=souli-vm
# GCE_ZONE=us-central1-a
# GCE_MACHINE_TYPE=n1-standard-4
# GCE_GPU_TYPE=nvidia-tesla-t4
# GCE_DISK_SIZE=100

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub Repository (for setup scripts)
# ═══════════════════════════════════════════════════════════════════════════════

SOULI_REPO_URL=https://github.com/LeapX-Tech/soul-i
