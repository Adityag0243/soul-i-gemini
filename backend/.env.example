DATABASE_URL="prisma+postgres://localhost:51213/?api_key=eyJkYXRhYmFzZVVybCI6InBvc......."

# Port 
PORT=9090

# Node environment
NODE_ENV=development

# Timezone
TZ=in

# Origin
ORIGIN_URL=http://localhost:3000


# Token Info
ACCESS_TOKEN_VALIDITY_SEC=172800
REFRESH_TOKEN_VALIDITY_SEC=604800
TOKEN_ISSUER=api.dev.xyz.com
TOKEN_AUDIENCE=xyz.com
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwgg....."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKC....."

# cookie info
COOKIE_MAX_AGE_SEC=
COOKIE_DOMAIN=.your-domain.com

# Directory for logs
LOG_DIRECTORY=%                                                                                                                                 

# Google OAuth (required for /auth/google and /auth/link/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI service (used by chat module)
AI_SERVICE_URL=http://localhost:11434
AI_MODEL=llama3.2
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# LiveKit Voice (required for /voice/token)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=souli-room
LIVEKIT_TOKEN_VALIDITY_SEC=900

# ── AWS SES Email Configuration ──────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
FROM_EMAIL=noreply@souli.com
FROM_NAME=Souli

# ── Stripe Payment Gateway ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_... # Get from Stripe Dashboard
STRIPE_PUBLISHABLE_KEY=pk_test_... # Get from Stripe Dashboard
STRIPE_PDF_ENDPOINT=https://api.stripe.com
STRIPE_WEBHOOK_SECRET=whsec_test_... # Generated after creating webhook endpoint in Stripe

# ── Razorpay Payment Gateway ─────────────────────────────────────────────
RAZORPAY_KEY_ID= # Get from Razorpay Dashboard
RAZORPAY_KEY_SECRET= # Get from Razorpay Dashboard
RAZORPAY_WEBHOOK_SECRET= # Generate your own webhook secret

# ── Subscription Configuration ───────────────────────────────────────────
SUBSCRIPTION_REMINDER_DAYS=7 # Days before expiry to send reminder (default: 7)
