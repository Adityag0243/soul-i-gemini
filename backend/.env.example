DATABASE_URL="prisma+postgres://localhost:51213/?api_key=eyJkYXRhYmFzZVVybCI6InBvc......."

# Port 
PORT=9090

# Node environment
NODE_ENV=development

# Timezone
TZ=in

# Origin
ORIGIN_URL=http://localhost:3000


# Token Info
ACCESS_TOKEN_VALIDITY_SEC=172800
REFRESH_TOKEN_VALIDITY_SEC=604800
TOKEN_ISSUER=api.dev.xyz.com
TOKEN_AUDIENCE=xyz.com
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwgg....."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKC....."

# cookie info
COOKIE_MAX_AGE_SEC=
COOKIE_DOMAIN=.your-domain.com

# Directory for logs
LOG_DIRECTORY=%                                                                                                                                 

# Google OAuth (required for /auth/google and /auth/link/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI service (used by chat module)
AI_SERVICE_URL=http://localhost:11434
AI_MODEL=llama3.2
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7

# LiveKit Voice (required for /voice/token)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM=souli-room
LIVEKIT_TOKEN_VALIDITY_SEC=900
